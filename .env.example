# Port the service runs on
PORT=3000

# SMTP Server Configurations
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Auth Credentials
SMTP_USER=your_smtp_username_or_email@example.com
SMTP_PASS=your_smtp_password

# Default sender email (if not specified in the API request)
SMTP_FROM_EMAIL="AstroFinix AI" <noreply@example.com>
