<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Download AstroFinix AI</title>
  <style>
    body {
      font-family: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background-color: #0b0f19;
      color: #e2e8f0;
      margin: 0;
      padding: 0;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      background-color: #0b0f19;
      width: 100%;
      padding: 40px 0;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #131a2e;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
      border: 1px solid #1e293b;
    }
    .top-section {
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
      padding: 50px 30px;
      text-align: center;
      border-bottom: 1px solid #334155;
    }
    .play-store-badge {
      display: inline-block;
      transition: transform 0.2s ease, filter 0.2s ease;
    }
    .play-store-badge:hover {
      transform: translateY(-2px);
      filter: brightness(1.1);
    }
    .play-store-badge img {
      width: 200px;
      height: auto;
      display: block;
    }
    .content {
      padding: 40px;
      text-align: left;
    }
    .greeting {
      font-size: 24px;
      font-weight: 700;
      color: #ffffff;
      margin: 0 0 20px;
    }
    .message-text {
      font-size: 16px;
      color: #cbd5e1;
      line-height: 1.8;
      margin: 0;
    }
    .highlight {
      color: #10b981;
      font-weight: 600;
    }
    .footer {
      background-color: #0b0f19;
      padding: 30px;
      text-align: center;
      font-size: 12px;
      color: #64748b;
      border-top: 1px solid #1e293b;
    }
    .footer p {
      margin: 0 0 10px;
    }
    .footer a {
      color: #10b981;
      text-decoration: none;
    }
  </style>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="wrapper">
    <div class="container">
      <!-- Top Section -->
      <div class="top-section">
        <a href="https://play.google.com/store/apps/details?id=com.astrofinix.ai" class="play-store-badge" target="_blank">
          <img src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png" alt="Get it on Google Play" />
        </a>
      </div>

      <!-- Main Body Content -->
      <div class="content">
        <h2 class="greeting">Hello <%= name || 'Seeker' %>,</h2>
        
        <p class="message-text">
          Take your astrological journey to the next level by downloading the AstroFinix app directly from the Play Store! 
          <br><br>
          Unlock <span class="highlight">advanced features</span>, check your <span class="highlight">daily horoscope</span>, monitor your <span class="highlight">daily energy status</span>, and chat instantly with your personal AI Astrologer wherever you go. Don't miss out on everything the cosmos has to offer!
        </p>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>&copy; <%= new Date().getFullYear() %> AstroFinix AI. All rights reserved.</p>
        <p>You received this email because you registered on <a href="https://astrofinix.com">astrofinix.com</a>.</p>
      </div>
    </div>
  </div>
</body>
</html>
